{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "ES2022"
        ],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "noEmit": true,
        "strict": true,
        "baseUrl": "..",
        "paths": {
            "@/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}